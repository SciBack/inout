# ── Base de datos PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=inout
POSTGRES_USER=inout
POSTGRES_PASSWORD=cambiar_esto

# ── Koha global (fallback si no hay config por sede) ───────────────────────
# Usar solo si todas las sedes comparten el mismo Koha (ej: después de unificar)
KOHA_API_URL=https://koha.institucion.edu.pe/api/v1
KOHA_API_USER=inout-api
KOHA_API_PASS=cambiar_esto
KOHA_VERIFY_SSL=false

# ── Koha por sede (REST API) ───────────────────────────────────────────────
# Si están vacíos se usa el KOHA_API_* global
KOHA_BUL_API_URL=https://koha-lima.institucion.edu.pe/api/v1
KOHA_BUL_API_USER=inout-api
KOHA_BUL_API_PASS=

KOHA_BUT_API_URL=https://koha-tarapoto.institucion.edu.pe/api/v1
KOHA_BUT_API_USER=inout-api
KOHA_BUT_API_PASS=

KOHA_BUJ_API_URL=https://koha-juliaca.institucion.edu.pe/api/v1
KOHA_BUJ_API_USER=inout-api
KOHA_BUJ_API_PASS=

KOHA_CIA_API_URL=
KOHA_CIA_API_USER=
KOHA_CIA_API_PASS=

# ── Koha DB directa por sede (para fotos de patrons) ──────────────────────
# BUL (Lima) — DB principal
KOHA_DB_HOST=
KOHA_DB_USER=
KOHA_DB_PASS=
KOHA_DB_NAME=

# BUT (Tarapoto)
KOHA_BUT_DB_HOST=
KOHA_BUT_DB_USER=
KOHA_BUT_DB_PASS=
KOHA_BUT_DB_NAME=

# BUJ (Juliaca)
KOHA_BUJ_DB_HOST=
KOHA_BUJ_DB_USER=
KOHA_BUJ_DB_PASS=
KOHA_BUJ_DB_NAME=

# ── Espacio por defecto ────────────────────────────────────────────────────
DEFAULT_SPACE_ID=1
DEFAULT_SPACE_CAPACITY=150
DEFAULT_SPACE_NAME=Biblioteca

# ── Seguridad ──────────────────────────────────────────────────────────────
SECRET_KEY=cambiar_esto_con_openssl_rand_hex_32
ADMIN_INITIAL_PASSWORD=admin123
